{
  "name": "tatvaops-blog-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_DISABLE_DEVTOOLS=1 next dev",
    "dev:clean": "rm -rf .next && NEXT_DISABLE_DEVTOOLS=1 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/seedBlogs.ts",
    "seed:reset": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/seedBlogs.ts --reset",
    "scheduler:daily": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/dailyRandomBlogScheduler.ts"
  },
  "dependencies": {
    "@radix-ui/react-separator": "^1.1.7",
    "dotenv": "^16.4.7",
    "iron-session": "^8.0.4",
    "lru-cache": "^11.3.5",
    "mongoose": "^8.15.1",
    "next": "^15.3.2",
    "pino": "^10.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@tailwindcss/typography": "^0.5.16",
    "@types/cookie": "^0.6.0",
    "@types/node": "^22.15.30",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4.1.8",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "5.9.3"
  }
}
