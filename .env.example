# MongoDB connection string (required)
MONGODB_URI=

# Public site URL — no trailing slash (required; must not be localhost in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI API key for AI blog generation (required)
OPENAI_API_KEY=
# Groq API key for primary AI generation (optional if OPENAI_API_KEY is set)
GROQ_API_KEY=
# Optional OpenAI image model for cover generation (default: gpt-image-1)
# OPENAI_IMAGE_MODEL=gpt-image-1
# Optional Unsplash API key for photo fallback provider
UNSPLASH_ACCESS_KEY=
# Image storage driver: local | cloud (cloud is reserved for future S3/Cloudinary plugin)
IMAGE_STORAGE_DRIVER=local
# If true, downloaded copies of remote image URLs are stored under /public/uploads/blog-covers
IMAGE_LOCALIZE_REMOTE=false

# NextAuth — public URL of the site (required in production)
NEXTAUTH_URL=http://localhost:3000
# NextAuth secret — generate with: openssl rand -base64 32 (required)
NEXTAUTH_SECRET=

# Google OAuth credentials — create at https://console.cloud.google.com/apis/credentials (required for Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Set to "true" to enable the admin CMS (required)
ADMIN_BLOG_ENABLED=true

# Admin password for /admin/login — use a strong random value (required)
ADMIN_BLOG_SECRET=

# Session encryption secret — must be at least 32 characters (required)
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Optional: "debug" | "info" | "warn" | "error" (default: info in prod, debug in dev)
# LOG_LEVEL=info

# Resend API key for newsletter digest sending (optional; required only for digest send endpoint)
RESEND_API_KEY=
# Sender identity for newsletter emails
NEWSLETTER_FROM="TatvaOps Blog <onboarding@resend.dev>"

# Enable background scheduler for 5 random AI blogs/day.
# Run with: npm run scheduler:daily
DAILY_AUTO_BLOGS_ENABLED=false
# Optional: generate one blog immediately when scheduler starts.
DAILY_AUTO_BLOGS_RUN_ON_START=false
