# MongoDB connection string (required)
MONGODB_URI=

# Public site URL — no trailing slash (required; must not be localhost in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI API key for AI blog generation (required)
OPENAI_API_KEY=
# Groq API key for primary AI generation (optional if OPENAI_API_KEY is set)
GROQ_API_KEY=

# Set to "true" to enable the admin CMS (required)
ADMIN_BLOG_ENABLED=true

# Admin password for /admin/login — use a strong random value (required)
ADMIN_BLOG_SECRET=

# Session encryption secret — must be at least 32 characters (required)
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Optional: "debug" | "info" | "warn" | "error" (default: info in prod, debug in dev)
# LOG_LEVEL=info

# Enable background scheduler for 5 random AI blogs/day.
# Run with: npm run scheduler:daily
DAILY_AUTO_BLOGS_ENABLED=false
# Optional: generate one blog immediately when scheduler starts.
DAILY_AUTO_BLOGS_RUN_ON_START=false
